#!/usr/bin/env bash
#
# Glyphh Code — post-commit hook
#
# Automatically recompiles changed files into the Glyphh index after
# every commit. Install with:
#
#   cp hooks/post-commit .git/hooks/post-commit
#   chmod +x .git/hooks/post-commit
#
# Or symlink so updates to the hook are picked up automatically:
#
#   ln -sf ../../hooks/post-commit .git/hooks/post-commit
#
# Requires: GLYPHH_COMPILE_PATH set to the path of compile.py
#           (or compile.py on PATH / in the same repo)
#
# Configuration (environment variables):
#   GLYPHH_RUNTIME_URL   Runtime endpoint (default: http://localhost:8002)
#   GLYPHH_TOKEN         Auth token (auto-resolved from CLI session if unset)
#   GLYPHH_ORG_ID        Org ID (auto-resolved from CLI session if unset)
#   GLYPHH_COMPILE_PATH  Path to compile.py (default: search common locations)
#   GLYPHH_HOOK_DISABLE  Set to "1" to temporarily disable the hook
#

set -euo pipefail

# Allow disabling the hook without removing it
if [ "${GLYPHH_HOOK_DISABLE:-}" = "1" ]; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Locate compile.py
if [ -n "${GLYPHH_COMPILE_PATH:-}" ]; then
    COMPILE="$GLYPHH_COMPILE_PATH"
elif [ -f "$REPO_ROOT/compile.py" ]; then
    COMPILE="$REPO_ROOT/compile.py"
else
    # If model-code is cloned elsewhere, the user must set GLYPHH_COMPILE_PATH
    echo "glyphh: post-commit hook skipped (compile.py not found, set GLYPHH_COMPILE_PATH)" >&2
    exit 0
fi

# Build args
ARGS=("$REPO_ROOT" "--incremental")

if [ -n "${GLYPHH_RUNTIME_URL:-}" ]; then
    ARGS+=("--runtime-url" "$GLYPHH_RUNTIME_URL")
fi

if [ -n "${GLYPHH_TOKEN:-}" ]; then
    ARGS+=("--token" "$GLYPHH_TOKEN")
fi

if [ -n "${GLYPHH_ORG_ID:-}" ]; then
    ARGS+=("--org-id" "$GLYPHH_ORG_ID")
fi

# Run in background so it doesn't block the commit
python3 "$COMPILE" "${ARGS[@]}" &>/dev/null &
